  "keyFeatures": [
    "Multi-type monitoring: API, Ping, TCP, DNS, SSL, SQL, Heartbeat, GameDig, gRPC",
    "Incident management with timelines, updates, and acknowledgements",
    "Scheduled maintenance windows with user notifications",
    "Customizable public status pages with branding, light/dark mode, and localization",
    "Multi-page support from a single Kener instance",
    "Role-based access control and team collaboration",
    "Notifications via Email, Webhook, Slack, and Discord",
    "Embeddable status badges and widgets",
    "REST API for incidents, monitors, and reporting",
    "Analytics integrations: GA, Plausible, Mixpanel, Umami, Clarity",
    "SQLite, PostgreSQL, and MySQL database support",
    "Docker-first deployment with Redis-backed queues"
  ],
  "publicApiSurface": [
    "GET /api/v4/monitors",
    "GET/POST/PATCH/DELETE /api/v4/monitors/:tag",
    "GET /api/v4/incidents",
    "POST /api/v4/incidents",
    "PATCH/DELETE /api/v4/incidents/:id",
    "GET /api/v4/maintenances",
    "POST /api/v4/maintenances",
    "GET /api/v4/pages",
    "GET /api/v4/site",
    "MonitorStatus: UP | DOWN | DEGRADED | MAINTENANCE | NO_DATA",
    "MonitorType: API | PING | TCP | DNS | SSL | SQL | HEARTBEAT | GAMEDIG | GRPC | GROUP | NONE",
    "IncidentState: INVESTIGATING | IDENTIFIED | MONITORING | RESOLVED"
  ]
